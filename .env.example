# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=yourpassword
PGDATABASE=queuestorm

# Credential encryption key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QUEUESTORM_SECRET=your_64_char_hex_key_here

# Server
PORT=3001
NODE_ENV=development
